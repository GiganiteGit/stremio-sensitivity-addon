# Copy to .env.local and fill in. .env.local is git-ignored (see .gitignore: .env*).
# The Phase 0 spike script loads this via: node --env-file=.env.local <script>.js

# DoesTheDogDie API key — sent as the X-API-KEY request header.
# Request one from https://www.doesthedogdie.com (email on their site).
# Required from Phase 0 onward. Put the REAL key in .env.local, never here.
DTDD_API_KEY=ddd_your_key_here

# Supabase — durable response cache, table dtdd_cache(imdb_id, payload, fetched_at).
# Create the table with supabase/dtdd_cache.sql (its RLS lets the ANON key upsert
# this one table). SUPABASE_KEY = the project's anon/public key, NOT service_role.
# Leave both blank to run on the in-memory cache only (the addon degrades gracefully).
SUPABASE_URL=
SUPABASE_KEY=

# Optional: max concurrent requests to DoesTheDogDie (politeness). Default 2.
# DTDD_CONCURRENCY=2

# Public base URL where this addon is hosted, used to build the manifest's
# logo/background URLs. Set at deploy (no trailing slash); defaults to the local
# dev server (http://127.0.0.1:7000) when unset.
# ADDON_BASE_URL=https://your-host.example.com
