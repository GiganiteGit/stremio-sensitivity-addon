# Copy to .env.local and fill in. .env.local is git-ignored (see .gitignore: .env*).
# The Phase 0 spike script loads this via: node --env-file=.env.local <script>.js

# DoesTheDogDie API key — sent as the X-API-KEY request header.
# Request one from https://www.doesthedogdie.com (email on their site).
# Required from Phase 0 onward. Put the REAL key in .env.local, never here.
DTDD_API_KEY=ddd_your_key_here

# Supabase — response cache table dtdd_cache(imdb_id, payload, fetched_at).
# Only needed from Phase 4. Use this addon's OWN project, or reuse an existing
# Supabase project if you'd rather share one cache. NOT FindMyLegacy's prod keys.
SUPABASE_URL=
SUPABASE_KEY=
